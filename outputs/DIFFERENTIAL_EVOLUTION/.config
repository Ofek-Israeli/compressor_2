
#
# Data Paths
#
CONFIG_FINANCEBENCH_JSONL="../financebench/data/financebench_open_source.jsonl"
CONFIG_FINANCEBENCH_POOL_INDICES="132, 42, 63, 30, 88, 51, 69, 81, 39, 115, 145, 140, 46, 92, 113"
CONFIG_CLUSTER_DESCRIPTIONS_PATH="outputs/cluster_descriptions.json"
CONFIG_INITIAL_DELTAS_PATH="outputs/deltas_examples.json"
CONFIG_KMEANS_PATH="outputs/labels_kmeans.joblib"
CONFIG_EMBEDDINGS_PATH="outputs/embeddings.npy"
CONFIG_OUTPUT_DIR="outputs/evolution"
# end of Data Paths

# CONFIG_OPT_METHOD_DEAP is not set
# CONFIG_OPT_METHOD_GRID_SEARCH is not set
# CONFIG_OPT_METHOD_RANDOM_SEARCH is not set
# CONFIG_OPT_METHOD_SPSA is not set
# CONFIG_OPT_METHOD_RANDOM_DIRECTION_2PT is not set
CONFIG_OPT_METHOD_DIFFERENTIAL_EVOLUTION=y
# CONFIG_OPT_METHOD_CMAES is not set
# CONFIG_OPT_METHOD_OPTUNA_TPE is not set
# CONFIG_OPT_METHOD_SMAC is not set
# CONFIG_OPT_METHOD_TR_DFO is not set
# CONFIG_OPT_METHOD_SKOPT is not set
# CONFIG_OPT_METHOD_HYBRID is not set

#
# Fitness & Scoring
#
CONFIG_LAMBDA_SHORTNESS="0.4"
CONFIG_LAMBDA_CORRECTNESS="0.6"
CONFIG_SHORTNESS_SCALE=600
# end of Fitness & Scoring

#
# Correctness
#
CONFIG_CORRECTNESS_MODEL="gpt-4o"
CONFIG_CORRECTNESS_TOLERANCE="0.10"
CONFIG_MINIONS_REPO="/workspace/minions_channel"
# end of Correctness

#
# SGLang Server
#
CONFIG_SGLANG_MODEL_PATH="meta-llama/Llama-3.1-8B-Instruct"
CONFIG_SGLANG_PORT=8000
CONFIG_SGLANG_EXTRA_ARGS=""
CONFIG_SGLANG_HEALTH_TIMEOUT=300
CONFIG_SGLANG_HEALTH_INTERVAL=5
# end of SGLang Server

#
# FinanceBench Runner
#
CONFIG_RUNNER_CONFIG_PATH="../financebench_runner/.config"
CONFIG_RUNNER_TIMEOUT_S=150
# end of FinanceBench Runner

#
# Generate Processor
#
CONFIG_EMBEDDING_MODEL="all-mpnet-base-v2"
CONFIG_GEN_BATCH_SIZE=512
# end of Generate Processor

#
# Evaluation Budget & Bounds
#
CONFIG_ZERO_ORDER_MAX_EVALS=500
CONFIG_EVAL_MINIBATCH_SIZE=15
CONFIG_EVAL_SEED=42
CONFIG_DELTAS_BOUND_LOW="-5.0"
CONFIG_DELTAS_BOUND_HIGH="5.0"
CONFIG_EVAL_TIMEOUT_S=600
CONFIG_EVAL_MAX_RETRIES=1
CONFIG_EVAL_FAILURE_FITNESS="-1000000000"
CONFIG_OPTIMIZER_SEED=0
CONFIG_EVAL_DETERMINISTIC=y
CONFIG_INFERENCE_SEED=0
CONFIG_LLM_MAX_TOKENS=2048
CONFIG_ENABLE_CACHE=y
CONFIG_CACHE_ROUND_DECIMALS=6
CONFIG_RUN_FINAL_FULL_POOL_EVAL=y
# end of Evaluation Budget & Bounds
